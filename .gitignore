!data/interim/
!data/processed/
!data/interim/paper_panel_raw.parquet
!data/interim/paper_panel_v1.parquet
!data/interim/paper_panel_v2.parquet
!data/interim/modis_province_monthly.parquet
!data/interim/nasa_power_annual.csv
!data/interim/spei_province_annual.csv
!data/interim/province_centroids.csv
