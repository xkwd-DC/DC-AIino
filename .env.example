# 数据采集 pipeline 凭证模板（这份入库，仅占位符）
# 实际值写到 .env（已 gitignored）

# NASA EARTHDATA — 用于 earthaccess / AppEEARS LST 下载
# 注册：https://urs.earthdata.nasa.gov/
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# 天地图 — 网页登录手动下 GS(2024)0650
# 注册：https://map.tianditu.gov.cn/
TIANDITU_USERNAME=
TIANDITU_PASSWORD=

# 国家地球系统科学数据中心（月度 NDVI 来源）
# 注册：https://www.geodata.cn
GEODATA_CN_USERNAME=
GEODATA_CN_PASSWORD=

# ── v4 新增数据源（见 docs/coord/2026-05-27_v4_account_checklist.md）──

# 国家青藏高原科学数据中心（v4 8a.2 农业灾害分布）
# 注册：https://data.tpdc.ac.cn/
TPDC_USERNAME=
TPDC_PASSWORD=

# 中科院资源环境科学与数据中心（v4 8a.2 备选）
# 注册：https://www.resdc.cn/
RESDC_USERNAME=
RESDC_PASSWORD=

# 国家气象科学数据中心（v4 8a.3 站点 daily 校准，可选；1-2 周审批长尾）
# 注册：http://data.cma.cn/
CMA_USERNAME=
CMA_PASSWORD=

# Zenodo（v4 8c CLCD 2011-2023；1000 req/h 配额，无需登录即可下载）
# 注册：https://zenodo.org/
ZENODO_TOKEN=
