# 复制为 .env 后按需修改。.env 已在 .gitignore 中。

# Flask 监听端口（dev: python app.py 使用；prod: gunicorn -b 自己指定）
PORT=5000

# 允许跨域的前端来源。**生产必须收窄**到具体域名,多个用逗号分隔。
# wildcard `*` 在 5915084 commit 后会触发启动 warning,但不阻断运行;
# 部署到 GCP 时务必改成实际域名以避免 CSRF/CORS 攻击。
# 例:CORS_ORIGINS=https://grainrisk.app,https://www.grainrisk.app
CORS_ORIGINS=https://grainrisk.app

# === 可选 ===

# flask-limiter 存储后端(可选,默认 in-memory)
# 多 worker 部署(gunicorn -w >1)需用 redis 共享速率状态,例:
# RATELIMIT_STORAGE_URI=redis://localhost:6379
# RATELIMIT_STORAGE_URI=
